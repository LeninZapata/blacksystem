            ],
            "onLoad": "resumeStats.init()",
            "content": [
              {
                "type": "html",
                "content": "<div class='og-bg-gray-100 og-px-2 og-p-1 og-rounded-lg og-mb-1'><h3 class='og-mt-0 og-mb-2 og-text-gray-800'>🔍 Filtros</h3><form id='resume-filters-form' class='og-form-group'><div class='og-gap-md og-mb-2'><div class='og-mb-2'><label for='resume-filter-bot' class='og-mb-1'>🤖 Bot</label><select id='resume-filter-bot' class='form-control'><option value=''>Todos los bots</option></select></div></div><div><label class='og-mb-1'>📅 Rango de Fechas</label><div class='btn-group og-flex og-wrap' role='group'><input type='radio' name='resume_date_range' id='resume-range-today' value='today' class='btn-group-input' checked><label for='resume-range-today' class='btn btn-group-item btn-sm'>Hoy</label><input type='radio' name='resume_date_range' id='resume-range-yesterday' value='yesterday' class='btn-group-input'><label for='resume-range-yesterday' class='btn btn-group-item btn-sm'>Ayer</label><input type='radio' name='resume_date_range' id='resume-range-yesterday-today' value='yesterday_today' class='btn-group-input'><label for='resume-range-yesterday-today' class='btn btn-group-item btn-sm'>Ayer y Hoy</label><input type='radio' name='resume_date_range' id='resume-range-3days' value='last_3_days' class='btn-group-input'><label for='resume-range-3days' class='btn btn-group-item btn-sm'>Hace 3 días</label><input type='radio' name='resume_date_range' id='resume-range-7days' value='last_7_days' class='btn-group-input'><label for='resume-range-7days' class='btn btn-group-item btn-sm'>Hace 7 días</label><input type='radio' name='resume_date_range' id='resume-range-15days' value='last_15_days' class='btn-group-input'><label for='resume-range-15days' class='btn btn-group-item btn-sm'>Hace 15 días</label><input type='radio' name='resume_date_range' id='resume-range-this-month' value='this_month' class='btn-group-input'><label for='resume-range-this-month' class='btn btn-group-item btn-sm'>Este mes</label><input type='radio' name='resume_date_range' id='resume-range-last-month' value='last_month' class='btn-group-input'><label for='resume-range-last-month' class='btn btn-group-item btn-sm'>Mes pasado</label><input type='radio' name='resume_date_range' id='resume-range-30days' value='last_30_days' class='btn-group-input'><label for='resume-range-30days' class='btn btn-group-item btn-sm'>Hace 30 días</label><input type='radio' name='resume_date_range' id='resume-range-custom' value='custom_date' class='btn-group-input'><label for='resume-range-custom' class='btn btn-group-item btn-sm'>Día específico</label></div><div id='resume-custom-date-container' style='display:none; margin-top: 0.75rem;'><label class='og-mb-1'>📅 Selecciona una fecha</label><input type='date' id='resume-custom-date-input' class='form-control' style='max-width: 200px;'></div></div></form></div>"
              },
              {
                "type": "html",
                "content": "<div id='resume-products-container'></div>"
