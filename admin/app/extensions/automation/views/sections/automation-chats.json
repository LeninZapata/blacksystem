{
  "id": "automationChats",
  "title": "💬 Chats",
  "type": "content",
  "styles": ["automation/assets/css/chat.css"],
  "scripts": ["automation/assets/js/date.js", "automation/assets/js/chat.js"],
  "content": [
    {
      "type": "html",
      "order": 0,
      "content": "<div class='bs-chat'><div class='bs-chat-sidebar'><div class='bs-chat-sidebar-header'><span>💬 Contactos</span><button class='bs-chat-filter-btn' id='bsChatFilterBtn' onclick='chat.toggleFilterPanel()' title='Filtros'><svg width='14' height='14' viewBox='0 0 16 16' fill='currentColor'><path d='M1.5 2A.5.5 0 0 1 2 1.5h12a.5.5 0 0 1 .354.854l-4.5 4.5A.5.5 0 0 0 9.5 7.207V13.5a.5.5 0 0 1-.276.447l-3 1.5A.5.5 0 0 1 5.5 15V7.207a.5.5 0 0 0-.146-.353l-4.5-4.5A.5.5 0 0 1 1.5 2z'/></svg></button><button class='bs-chat-refresh-btn' onclick='chat.refreshClients()' title='Actualizar contactos'>↻</button></div><div id='bsChatFilterPanel' class='bs-chat-filter-panel' style='display:none'><div class='og-grid og-cols-2 og-keep-mobile og-gap-sm'><label class='bs-chat-filter-confirmed'><input type='checkbox' id='bsChatTodayFilter' onchange='chat.onTodayFilter(this.checked)'> Solo hoy</label><label class='bs-chat-filter-confirmed'><input type='checkbox' id='bsChatConfirmedFilter' onchange='chat.onConfirmedFilter(this.checked)'> Solo ventas</label></div></div><div id='bsChatList' class='bs-chat-list'><div id='bsChatLoadMore' class='bs-chat-loadmore' style='display:none'><button class='btn btn-secondary' onclick='chat.loadMore()'>Cargar más</button></div></div></div><div class='bs-chat-panel'><div id='bsChatHeader' class='bs-chat-panel-header bs-chat-no-client'><span>Selecciona un contacto para ver la conversación</span></div><div id='bsChatMain' class='bs-chat-main'></div><div id='bsChatCompose' class='bs-chat-compose' style='display:none'><textarea id='bsChatInput' class='bs-chat-input' placeholder='Escribe un mensaje...' rows='1' onkeydown='chat.onKeyDown(event)'></textarea><button class='btn btn-primary bs-chat-send-btn' onclick='chat.sendMessage()'>Enviar</button></div></div></div>"
    }
  ]
}
