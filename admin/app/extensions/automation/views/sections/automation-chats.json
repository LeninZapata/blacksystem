      "content": "<div class='bs-chat'><div class='bs-chat-sidebar'><div class='bs-chat-sidebar-header'><div id='bsChatTimeBlock' class='bs-chat-time-block'><div id='bsChatClock' class='bs-chat-clock-line'></div><div id='bsChatLastActivity' class='bs-chat-activity-line'></div></div><button class='bs-chat-filter-btn' id='bsChatFilterBtn' onclick='chat.toggleFilterPanel()' title='Filtros'><svg width='14' height='14' viewBox='0 0 16 16' fill='currentColor'><path d='M1.5 2A.5.5 0 0 1 2 1.5h12a.5.5 0 0 1 .354.854l-4.5 4.5A.5.5 0 0 0 9.5 7.207V13.5a.5.5 0 0 1-.276.447l-3 1.5A.5.5 0 0 1 5.5 15V7.207a.5.5 0 0 0-.146-.353l-4.5-4.5A.5.5 0 0 1 1.5 2z'/></svg></button><button class='bs-chat-refresh-btn' onclick='chat.refreshClients()' title='Actualizar contactos'>↻</button></div><div id='bsChatFilterPanel' class='bs-chat-filter-panel' style='display:none'><div class='bs-chat-filter-row'><label class='bs-chat-filter-confirmed'><input type='checkbox' id='bsChatTodayFilter' onchange='chat.onTodayFilter(this.checked)'> Solo hoy</label><label class='bs-chat-filter-confirmed'><input type='checkbox' id='bsChatConfirmedFilter' onchange='chat.onConfirmedFilter(this.checked)'> Solo ventas</label><div class='bs-chat-number-filter'><input type='text' id='bsChatNumberInput' placeholder='número...' onkeydown='chat.onNumberKeyDown(event)'><button onclick='chat.onNumberFilter()' title='Buscar por número'><svg width='12' height='12' viewBox='0 0 16 16' fill='currentColor'><path d='M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z'/></svg></button></div></div></div><div id='bsChatList' class='bs-chat-list'><div id='bsChatLoadMore' class='bs-chat-loadmore' style='display:none'><button class='btn btn-secondary' onclick='chat.loadMore()'>Cargar más</button></div></div></div><div class='bs-chat-panel'><div id='bsChatHeader' class='bs-chat-panel-header bs-chat-no-client'><span>Selecciona un contacto para ver la conversación</span></div><div id='bsChatMain' class='bs-chat-main'></div><div id='bsChatCompose' class='bs-chat-compose' style='display:none'><button class='btn btn-secondary bs-chat-options-btn' onclick='chat.openOptions()' title='Opciones'><svg width='14' height='14' viewBox='0 0 16 16' fill='currentColor'><path d='M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z'/><path d='M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.433-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.764-.415 1.6.42 1.184 1.185l-.159.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.415.764-.42 1.6-1.185 1.184l-.291-.159a1.873 1.873 0 0 0-2.693 1.116l-.094.318c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.184-1.185l.159-.291A1.873 1.873 0 0 0 1.945 8.93l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094A1.873 1.873 0 0 0 3.06 4.377l-.16-.292c-.415-.764.42-1.6 1.185-1.184l.292.159a1.873 1.873 0 0 0 2.692-1.115l.094-.319z'/></svg></button><textarea id='bsChatInput' class='bs-chat-input' placeholder='Escribe un mensaje...' rows='1' onkeydown='chat.onKeyDown(event)'></textarea><button class='btn btn-primary bs-chat-send-btn' onclick='chat.sendMessage()'>Enviar</button></div></div></div>"
    }
  ]
